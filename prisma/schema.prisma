// -----------------------------------------------------------------------------
// 《通用文学知识图谱系统》核心数据库定义
// -----------------------------------------------------------------------------

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// --- 枚举定义 (业务逻辑分类) ---

enum NameType {
  NAMED // 有名有姓的人物（默认）
  TITLE_ONLY // 仅有称号/官职/绰号，无名字

  @@map("name_type")
}

enum RecordSource {
  AI // AI 解析产出（默认）
  MANUAL // 用户手动录入

  @@map("record_source")
}

enum AppRole {
  ADMIN // 管理员：拥有系统配置与审核权限
  VIEWER // 只读用户：仅可查看数据

  @@map("app_role")
}

enum ProcessingStatus {
  DRAFT // AI 初步提取，待人工审核
  VERIFIED // 已人工核准，正式入库
  REJECTED // 噪音数据或错误识别

  @@map("processing_status")
}

enum AnalysisJobStatus {
  QUEUED // 已入队，等待调度
  RUNNING // 执行中
  SUCCEEDED // 执行成功
  FAILED // 执行失败
  CANCELED // 人工或系统取消

  @@map("analysis_job_status")
}

enum ModelStrategyScope {
  GLOBAL
  BOOK
  JOB

  @@map("model_strategy_scope")
}

enum AliasType {
  TITLE // 封号/尊号，如太祖皇帝、吴王
  POSITION // 职位称呼，如丞相、知府
  KINSHIP // 亲属代称，如皇后、世子
  NICKNAME // 绰号/外号，如范老爷
  COURTESY_NAME // 字号，如子美

  @@map("alias_type")
}

enum AliasMappingStatus {
  PENDING // 待确认
  CONFIRMED // 已确认
  LLM_INFERRED // AI 仲裁推断，待后续验证升级
  REJECTED // 已拒绝

  @@map("alias_mapping_status")
}

enum PersonaType {
  PERSON // 人物
  LOCATION // 地点（州县、官署、名胜）
  ORGANIZATION // 组织（家族、帮派、学院）
  CONCEPT // 关键概念/物件（如：严监生的两根灯草）

  @@map("persona_type")
}

enum BioCategory {
  BIRTH // 出生
  EXAM // 科举/晋升（中举、落第、授职）
  CAREER // 官职变动/职业生涯（升迁、罢官、调任）
  TRAVEL // 游历/搬迁（进京、返乡）
  SOCIAL // 重大社交（寿宴、雅集、结盟）
  DEATH // 卒
  EVENT // 普通重要情节

  @@map("bio_category")
}

enum ChapterType {
  /**
   * 楔子/序幕：通常是总纲性质的章节，概括全书大义，介绍主要人物和背景。
   */
  PRELUDE // 楔子 / 序幕
  /**
   * 正文回目：书籍的核心章节，按照时间顺序展开故事情节和人物关系。
   */
  CHAPTER // 正文回目
  /**
   * 后记/尾声：总结全书内容，回顾人物命运，或提供作者的反思和评论。
   */
  POSTLUDE // 后记 / 尾声

  @@map("chapter_type")
}

// --- 核心模型 ---

/// @db.remark: 系统用户。仅存 admin / viewer 账号，初始管理员由 seed 从 env 写入。
model User {
  id          String    @id @default(uuid()) @db.Uuid // 用户主键
  username    String    @unique // 系统内用户名/标识（唯一），不作为主登录凭证
  email       String    @unique // 登录邮箱（唯一）
  name        String    @default("管理员") // 展示名
  password    String    @map("password") // Argon2id 密码哈希，不存明文
  role        AppRole   @default(VIEWER) // 系统角色
  isActive    Boolean   @default(true) @map("is_active") // 账号启用状态
  lastLoginAt DateTime? @map("last_login_at") @db.Timestamptz(6) // 最近登录时间
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6) // 创建时间
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6) // 更新时间

  @@index([isActive], map: "users_is_active_idx") // 账号启用状态筛选索引
  @@map("users")
}

/// @db.remark: AI 模型配置表。存储各模型的 Key、BaseURL 及启用状态，由设置页管理。
model AiModel {
  id        String     @id @default(uuid()) @db.Uuid // 模型配置主键
  provider  String // 推荐值: "deepseek" | "qwen" | "doubao" | "gemini" | "glm"
  name      String // 显示名称，如 "DeepSeek V3"
  modelId   String     @map("model_id") // 供应商 API 调用标识，如 "deepseek-chat"
  aliasKey  String?    @map("alias_key") // 语义别名键（用于阶段推荐与版本平滑升级）
  baseUrl   String     @map("base_url") // 可自定义，支持私有部署
  apiKey    String?    @map("api_key") // 前端只展示脱敏版
  isEnabled Boolean    @default(false) @map("is_enabled") // Key 配置后才可启用
  isDefault Boolean    @default(false) @map("is_default") // 导入向导默认选中

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6) // 创建时间
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6) // 更新时间

  phaseLogs AnalysisPhaseLog[] // 阶段调用日志

  @@index([provider, isEnabled], map: "ai_models_provider_enabled_idx")
  @@index([aliasKey], map: "ai_models_alias_key_idx")
  @@map("ai_models")
}

/// @db.remark: 书籍/作品库。系统的顶层容器，支持跨作品的人物对比。
model Book {
  id             String  @id @default(uuid()) @db.Uuid // 书籍主键
  title          String // 书名，如《儒林外史》
  author         String? // 作者，如"吴敬梓"
  dynasty        String? // 背景朝代
  genre          String? // 书籍类型预设键名（如"武侠""宫廷家族"），对应 GENRE_PRESETS，影响词典覆盖
  description    String? @db.Text // 作品简介
  coverUrl       String? @map("cover_url") // 3D 看板所需的封面图
  sourceFileKey  String? @map("source_file_key") // 原始导入文件的对象存储 key
  sourceFileUrl  String? @map("source_file_url") // 原始导入文件的可访问链接
  sourceFileName String? @map("source_file_name") // 用户上传时的原始文件名
  sourceFileMime String? @map("source_file_mime") // 原始文件 MIME 类型
  sourceFileSize Int?    @map("source_file_size") // 原始文件字节数
  deletedAt      DateTime? @map("deleted_at") @db.Timestamptz(6) // 软删除时间
  // PENDING (初始), PROCESSING (解析中), COMPLETED (完成), ERROR (失败)
  status        String  @default("PENDING") // 当前处理状态
  errorLog      String? @map("error_log") @db.Text // 最近失败日志
  parseProgress Int     @default(0) @map("parse_progress") // 解析进度 0-100
  parseStage    String? @map("parse_stage") // 当前阶段文本，如"实体提取"

  // 知识库关联：bookTypeId 为 genre 的结构化替代，过渡期两者并存
  bookTypeId     String? @map("book_type_id") @db.Uuid
  bookType       BookType? @relation(fields: [bookTypeId], references: [id])
  bookKnowledgePacks BookKnowledgePack[]

  chapters          Chapter[] // 章节列表
  profiles          Profile[] // 本书角色档案
  analysisJobs      AnalysisJob[] // 解析任务记录
  aliasMappings     AliasMapping[] // 别名映射记录
  modelStrategies   ModelStrategyConfig[] @relation("BookStrategies")
  validationReports ValidationReport[] // 自检报告
  mergeSuggestions MergeSuggestion[] // 人物合并建议队列
  createdAt    DateTime      @default(now()) @map("created_at") @db.Timestamptz(6) // 创建时间
  updatedAt    DateTime      @updatedAt @map("updated_at") @db.Timestamptz(6) // 更新时间

  @@index([deletedAt], map: "books_deleted_at_idx")
  @@map("books")
}

/// @db.remark: 章节/回目。时间轴的物理基石，所有事件必须挂载在回目上。
model Chapter {
  id          String      @id @default(uuid()) @db.Uuid // 章节主键
  bookId      String      @map("book_id") @db.Uuid // 所属书籍 ID
  type        ChapterType @default(CHAPTER) // 标注是楔子还是正文
  no          Int // 章节序号（第几回），决定时间轴物理排序
  unit        String      @default("回") // 称谓单位 (如: "回", "章", "节")
  noText      String?     @map("no_text") // 自定义序号显示 (如: "第一回", "序章")
  title       String // 章节名，如"范进中举"
  content     String      @db.Text // 章节原文（用于 AI 解析及前端高亮溯源）
  parseStatus String      @default("PENDING") @map("parse_status") // PENDING | PROCESSING | SUCCEEDED | FAILED

  // 针对文学作品的补充
  isAbstract Boolean  @default(false) @map("is_abstract") // 是否为总纲/大义
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6) // 创建时间
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz(6) // 更新时间

  book        Book              @relation(fields: [bookId], references: [id]) // 所属书籍
  mentions    Mention[] // 本章提及记录
  biographies BiographyRecord[] // 本章履历事件
  relations   Relationship[] // 本章关系边
  phaseLogs   AnalysisPhaseLog[] // 阶段调用日志

  @@unique([bookId, type, no], map: "chapter_book_type_no_key") // 联合唯一约束
  @@map("chapters") // 数据库物理表名：复数
}

/// @db.remark: 全局角色本体。代表"这个人本身"，支持跨书籍关联（如林黛玉在多本书中的统一 ID）。
model Persona {
  id     String      @id @default(uuid()) @db.Uuid // 角色本体主键
  name   String // 全局标准名（如"范进"）
  type   PersonaType @default(PERSON) // 实体类型
  gender String? // 性别

  // 人名类型与数据来源
  nameType     NameType     @default(NAMED) @map("name_type") // 人名类型
  recordSource RecordSource @default(AI) @map("record_source") // 记录来源
  confidence   Float        @default(1.0) // AI 置信度 0.0-1.0，低于 0.7 标记待核对

  // 跨书共享的静态属性
  aliases    String[]  @default([]) // 别名列表，如 ["周学道","周大人"]
  hometown   String? // 籍贯
  birthYear  String?   @map("birth_year") // 生年（虚拟或公历）
  deathYear  String?   @map("death_year") // 卒年
  globalTags String[]  @default([]) @map("global_tags") // 全局标签，如 ["真名士", "官僚"]
  deletedAt  DateTime? @map("deleted_at") @db.Timestamptz(6) // 软删除时间
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(6) // 创建时间
  updatedAt  DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6) // 更新时间

  profiles    Profile[] // 各书籍维度档案
  mentions    Mention[] // 角色提及集合
  biographies BiographyRecord[] // 角色的生平/职位变迁轨迹轨迹
  aliasMappings AliasMapping[] // 别名映射记录
  sourceMergeSuggestions MergeSuggestion[] @relation("MergeSuggestionSourcePersona")
  targetMergeSuggestions MergeSuggestion[] @relation("MergeSuggestionTargetPersona")

  // 建立双向关系关联，方便 3D 图谱从 Persona 直接出发查询
  sourceRels Relationship[] @relation("SourcePersona")
  targetRels Relationship[] @relation("TargetPersona")

  @@index([name], map: "persona_name_idx") // 人名检索索引
  @@index([deletedAt], map: "persona_deleted_at_idx") // 软删除清理索引
  @@map("personas")
}

/// @db.remark: 角色书中档案。记录该 Persona 在特定书籍中的特有属性（如讽刺指数）。
model Profile {
  id        String @id @default(uuid()) @db.Uuid // 档案主键
  personaId String @map("persona_id") @db.Uuid // 关联角色 ID
  bookId    String @map("book_id") @db.Uuid // 关联书籍 ID

  localName     String   @map("local_name") // 书中称呼：如"范老爷"
  localSummary  String?  @map("local_summary") @db.Text // AI 汇总的本书人物小传
  officialTitle String?  @map("official_title") // 书中官职（最终职位）
  localTags     String[] @default([]) @map("local_tags") // 性格/社会角色标签，如 ["伪君子","官僚"]
  ironyIndex    Float    @default(0) @map("irony_index") // 讽刺指数 (0-10)
  moralTier     String?  @map("moral_tier") // 人格档次，如"伪君子"

  // 3D 视觉配置缓存：存储节点颜色、发光度、初始坐标建议等
  visualConfig Json?     @map("visual_config") // 前端可视化配置缓存
  deletedAt    DateTime? @map("deleted_at") @db.Timestamptz(6) // 软删除时间
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6) // 创建时间
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6) // 更新时间

  persona Persona @relation(fields: [personaId], references: [id]) // 关联角色
  book    Book    @relation(fields: [bookId], references: [id]) // 关联书籍

  @@unique([personaId, bookId], map: "profile_persona_id_book_id_key") // 一角色在同一本书仅一条档案
  @@index([bookId, deletedAt], map: "profiles_book_id_deleted_at_idx") // 书籍维度的有效档案筛选索引
  @@map("profiles")
}

/// @db.remark: 履历记录表。时间轴的核心，记录职位、地点、状态的每一次跳动。
model BiographyRecord {
  id        String @id @default(uuid()) @db.Uuid // 履历主键
  personaId String @map("persona_id") @db.Uuid // 关联角色 ID
  chapterId String @map("chapter_id") @db.Uuid // 事件发生的章节坐标
  chapterNo Int    @map("chapter_no") // 冗余排序字段，极速生成 Timeline

  category    BioCategory @default(EVENT) // 事件分类
  title       String? // 当时的职位/身份，如"山东学道"
  location    String? // 所在的地理位置
  event       String      @db.Text // 事件具体描述
  virtualYear String?     @map("virtual_year") // 书中提到的时间点

  ironyNote    String?          @map("irony_note") @db.Text // AI 的解析点评
  recordSource RecordSource     @default(AI) @map("record_source") // 数据来源
  status       ProcessingStatus @default(DRAFT) // 审核状态
  deletedAt    DateTime?        @map("deleted_at") @db.Timestamptz(6) // 软删除时间
  createdAt    DateTime         @default(now()) @map("created_at") @db.Timestamptz(6) // 创建时间
  updatedAt    DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6) // 更新时间

  persona Persona @relation(fields: [personaId], references: [id]) // 关联角色
  chapter Chapter @relation(fields: [chapterId], references: [id]) // 关联章节

  @@index([chapterNo], map: "biography_record_chapter_no_idx") // 时间轴排序索引
  @@index([personaId], map: "biography_record_persona_id_idx") // 角色维度查询索引
  @@index([status, recordSource, chapterId], map: "biography_record_review_query_idx") // 审核列表查询索引
  @@map("biography_records")
}

/// @db.remark: 原文提及记录。记录"谁在什么时候出场了"，支持精准定位原文段落。
model Mention {
  id        String @id @default(uuid()) @db.Uuid // 提及主键
  personaId String @map("persona_id") @db.Uuid // 关联角色 ID
  chapterId String @map("chapter_id") @db.Uuid // 关联章节 ID

  rawText      String       @map("raw_text") // 原文提及片段，如"那范老爷"
  summary      String? // AI 提取的此次出场动态摘要
  paraIndex    Int?         @map("para_index") // 段落索引，用于定位原文
  recordSource RecordSource @default(AI) @map("record_source") // 数据来源
  deletedAt    DateTime?    @map("deleted_at") @db.Timestamptz(6) // 软删除时间
  createdAt    DateTime     @default(now()) @map("created_at") @db.Timestamptz(6) // 创建时间
  updatedAt    DateTime     @updatedAt @map("updated_at") @db.Timestamptz(6) // 更新时间

  persona Persona @relation(fields: [personaId], references: [id]) // 关联角色
  chapter Chapter @relation(fields: [chapterId], references: [id]) // 关联章节

  @@index([chapterId], map: "mentions_chapter_id_idx") // 按章节查询索引
  @@index([personaId, chapterId], map: "mention_persona_id_chapter_id_idx") // 人物章节联合查询索引
  @@index([chapterId, deletedAt], map: "mentions_chapter_deleted_at_idx") // 章节有效提及筛选索引
  @@map("mentions")
}

/// @db.remark: 动态关系表。
model Relationship {
  id        String @id @default(uuid()) @db.Uuid // 关系主键
  chapterId String @map("chapter_id") @db.Uuid // 关系确认的章节
  sourceId  String @map("source_id") @db.Uuid // 发起者 ID
  targetId  String @map("target_id") @db.Uuid // 接收者 ID

  type         String // 关系类型，如"同年"、"师生"
  weight       Float            @default(1.0) // 亲密度
  description  String?          @db.Text // 关系背景描述
  evidence     String?          @db.Text // 原文证据片段
  recordSource RecordSource     @default(AI) @map("record_source") // 数据来源
  confidence   Float            @default(1.0) // AI 置信度 0.0-1.0
  status       ProcessingStatus @default(DRAFT) // 审核状态
  deletedAt    DateTime?        @map("deleted_at") @db.Timestamptz(6) // 软删除时间
  createdAt    DateTime         @default(now()) @map("created_at") @db.Timestamptz(6) // 创建时间
  updatedAt    DateTime         @updatedAt @map("updated_at") @db.Timestamptz(6) // 更新时间

  chapter Chapter @relation(fields: [chapterId], references: [id]) // 关系确认章节
  source  Persona @relation("SourcePersona", fields: [sourceId], references: [id]) // 关系发起方
  target  Persona @relation("TargetPersona", fields: [targetId], references: [id]) // 关系接收方

  @@unique([chapterId, sourceId, targetId, type, recordSource], map: "relationships_dedup_key") // 防止重复关系边
  @@index([sourceId, targetId], map: "relationships_source_id_target_id_idx") // 双点关系查询索引
  @@index([status, recordSource, chapterId], map: "relationships_review_query_idx") // 审核列表查询索引
  @@map("relationships")
}

/// @db.remark: 解析任务审计表。记录每次全书/分章解析执行状态、重试与错误日志。
model AnalysisJob {
  id           String            @id @default(uuid()) @db.Uuid // 任务主键
  bookId       String            @map("book_id") @db.Uuid // 目标书籍 ID
  status         AnalysisJobStatus @default(QUEUED) // 任务状态
  architecture   String            @default("sequential") // sequential | twopass
  scope          String            @default("FULL_BOOK") // FULL_BOOK | CHAPTER_RANGE | CHAPTER_LIST
  chapterStart   Int?              @map("chapter_start") // 章节起点（范围任务）
  chapterEnd     Int?              @map("chapter_end") // 章节终点（范围任务）
  chapterIndices Int[]             @default([]) @map("chapter_indices") // 指定章节编号列表（CHAPTER_LIST 任务）
  attempt      Int               @default(1) // 当前重试次数
  errorLog     String?           @map("error_log") @db.Text // 失败摘要
  experimentTag String?          @map("experiment_tag")
  overrideStrategy String?       @map("override_strategy") // DRAFT_ONLY | ALL_DRAFTS
  keepHistory      Boolean       @default(false) @map("keep_history") // 是否保留历史草稿版本
  startedAt    DateTime?         @map("started_at") @db.Timestamptz(6) // 开始时间
  finishedAt   DateTime?         @map("finished_at") @db.Timestamptz(6) // 完成时间
  createdAt    DateTime          @default(now()) @map("created_at") @db.Timestamptz(6) // 创建时间
  updatedAt    DateTime          @updatedAt @map("updated_at") @db.Timestamptz(6) // 更新时间

  book            Book                 @relation(fields: [bookId], references: [id]) // 关联书籍
  modelStrategies ModelStrategyConfig[] @relation("JobStrategies")
  phaseLogs       AnalysisPhaseLog[]
  validationReports ValidationReport[] // 该任务生成的自检报告

  @@index([bookId, createdAt], map: "analysis_jobs_book_created_at_idx") // 书籍任务时间序查询索引
  @@index([status, createdAt], map: "analysis_jobs_status_created_at_idx") // 状态队列查询索引
  @@map("analysis_jobs")
}

/// @db.remark: 混合模型策略配置。支持 GLOBAL/BOOK/JOB 三层覆盖。
model ModelStrategyConfig {
  id        String             @id @default(uuid()) @db.Uuid
  scope     ModelStrategyScope
  bookId    String?            @map("book_id") @db.Uuid
  jobId     String?            @map("job_id") @db.Uuid
  stages    Json
  createdAt DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime           @updatedAt @map("updated_at") @db.Timestamptz(6)

  book        Book?        @relation("BookStrategies", fields: [bookId], references: [id], onDelete: Cascade)
  analysisJob AnalysisJob? @relation("JobStrategies", fields: [jobId], references: [id], onDelete: Cascade)

  @@unique([scope, bookId], map: "uq_strategy_book")
  @@unique([scope, jobId], map: "uq_strategy_job")
  @@index([scope], map: "model_strategy_scope_idx")
  @@map("model_strategy_configs")
}

/// @db.remark: AI 阶段调用日志。记录每次调用模型、耗时、token 及 fallback 信息。
model AnalysisPhaseLog {
  id               String   @id @default(uuid()) @db.Uuid
  jobId            String   @map("job_id") @db.Uuid
  chapterId        String?  @map("chapter_id") @db.Uuid
  stage            String
  modelId          String?  @map("model_id") @db.Uuid
  modelSource      String   @map("model_source")
  isFallback       Boolean  @default(false) @map("is_fallback")
  promptTokens     Int?     @map("prompt_tokens")
  completionTokens Int?     @map("completion_tokens")
  durationMs       Int?     @map("duration_ms")
  status           String
  errorMessage     String?  @map("error_message")
  chunkIndex       Int?     @map("chunk_index")
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  job     AnalysisJob @relation(fields: [jobId], references: [id], onDelete: Cascade)
  model   AiModel?    @relation(fields: [modelId], references: [id], onDelete: SetNull)
  chapter Chapter?    @relation(fields: [chapterId], references: [id], onDelete: SetNull)

  @@index([jobId, stage], map: "analysis_phase_logs_job_stage_idx")
  @@index([modelId], map: "analysis_phase_logs_model_idx")
  @@index([createdAt], map: "analysis_phase_logs_created_at_idx")
  @@map("analysis_phase_logs")
}

/// @db.remark: 别名映射表。记录章节上下文中的“称号/别名 -> 真实人物”映射。
model AliasMapping {
  id           String             @id @default(uuid()) @db.Uuid
  bookId       String             @map("book_id") @db.Uuid
  personaId    String?            @map("persona_id") @db.Uuid
  alias        String
  resolvedName String?            @map("resolved_name")
  aliasType    AliasType          @map("alias_type")
  confidence   Float              @default(0)
  evidence     String?            @db.Text
  status       AliasMappingStatus @default(PENDING)
  chapterStart Int?               @map("chapter_start")
  chapterEnd   Int?               @map("chapter_end")
  contextHash  String?            @map("context_hash")
  createdAt    DateTime           @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime           @updatedAt @map("updated_at") @db.Timestamptz(6)

  book    Book     @relation(fields: [bookId], references: [id], onDelete: Cascade)
  persona Persona? @relation(fields: [personaId], references: [id], onDelete: SetNull)

  @@index([bookId, alias], map: "alias_book_idx")
  @@index([bookId, personaId], map: "persona_book_idx")
  @@map("alias_mappings")
}

/// @db.remark: 自检报告。记录章节/全书级别的结构化质量检查结果。
model ValidationReport {
  id        String   @id @default(uuid()) @db.Uuid
  bookId    String   @map("book_id") @db.Uuid
  jobId     String?  @map("job_id") @db.Uuid
  scope     String
  chapterId String?  @map("chapter_id") @db.Uuid
  status    String   @default("PENDING")
  issues    Json
  summary   Json
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  book Book @relation(fields: [bookId], references: [id], onDelete: Cascade)
  job  AnalysisJob? @relation(fields: [jobId], references: [id], onDelete: SetNull)

  @@index([bookId], map: "validation_book_idx")
  @@index([bookId, chapterId], map: "validation_book_chapter_idx")
  @@index([jobId], map: "validation_job_idx")
  @@map("validation_reports")
}

/// @db.remark: 人物别名消歧建议。用于管理员审核同名/别名归并。
model MergeSuggestion {
  id              String    @id @default(uuid()) @db.Uuid
  bookId          String    @map("book_id") @db.Uuid
  sourcePersonaId String    @map("source_persona_id") @db.Uuid
  targetPersonaId String    @map("target_persona_id") @db.Uuid
  reason          String    @db.Text
  confidence      Float     @default(0)
  evidenceRefs    Json?     @map("evidence_refs")
  status          String    @default("PENDING")
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  resolvedAt      DateTime? @map("resolved_at") @db.Timestamptz(6)

  book          Book    @relation(fields: [bookId], references: [id], onDelete: Cascade)
  sourcePersona Persona @relation("MergeSuggestionSourcePersona", fields: [sourcePersonaId], references: [id], onDelete: Cascade)
  targetPersona Persona @relation("MergeSuggestionTargetPersona", fields: [targetPersonaId], references: [id], onDelete: Cascade)

  @@index([bookId, status], map: "merge_suggestions_book_status_idx")
  @@index([sourcePersonaId], map: "merge_suggestions_source_persona_idx")
  @@index([targetPersonaId], map: "merge_suggestions_target_persona_idx")
  @@map("merge_suggestions")
}

// =============================================================================
// 知识库模块：书籍类型 + 知识包 + 知识条目
// =============================================================================

/// @db.remark: 古典文学书籍类型定义表，存储 NER 词典规则配置，可在管理后台热更新。
model BookType {
  id          String  @id @default(uuid()) @db.Uuid
  key         String  @unique // 代码引用键，如"历史演义"，用于解析流水线配置查找
  name        String // 展示名称（可与 key 不同）

  /// NER 调谐配置（对应代码中的 BookLexiconConfig）。
  /// JSON 格式：{ exemptGenericTitles, additionalTitlePatterns, additionalPositionPatterns, softRelationalSuffixes }
  presetConfig Json? @map("preset_config")

  description String? @db.Text
  isActive    Boolean @default(true) @map("is_active")
  sortOrder   Int     @default(0) @map("sort_order")

  books          Book[]
  knowledgePacks KnowledgePack[]
  surnameEntries SurnameEntry[]

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([key], map: "book_types_key_idx")
  @@index([isActive, sortOrder], map: "book_types_active_sort_idx")
  @@map("book_types")
}

/// @db.remark: 知识包表。scope=GENRE 为书籍类型通用包，scope=BOOK 为书籍专属包。
model KnowledgePack {
  id          String  @id @default(uuid()) @db.Uuid
  bookTypeId  String? @map("book_type_id") @db.Uuid
  name        String
  description String? @db.Text
  version     Int     @default(1) // 版本号，支持增量更新追踪
  isActive    Boolean @default(true) @map("is_active")
  /// GENRE: 书籍类型级通用（所有该类型书籍自动继承）
  /// BOOK:  书籍专属（仅手动挂载的书籍使用）
  scope       String  @default("GENRE")

  bookType  BookType?           @relation(fields: [bookTypeId], references: [id])
  entries   KnowledgeEntry[]
  bookPacks BookKnowledgePack[]

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([bookTypeId, isActive], map: "knowledge_packs_book_type_active_idx")
  @@index([scope], map: "knowledge_packs_scope_idx")
  @@map("knowledge_packs")
}

/// @db.remark: 知识条目。reviewStatus 驱动审核工作流（PENDING→VERIFIED or REJECTED）。
model KnowledgeEntry {
  id            String @id @default(uuid()) @db.Uuid
  packId        String @map("pack_id") @db.Uuid

  canonicalName String   @map("canonical_name") // 标准全名，如「关羽」
  aliases       String[] @default([]) // 所有已知别名
  /// CHARACTER | LOCATION | ORGANIZATION
  entryType     String   @default("CHARACTER") @map("entry_type")
  confidence    Float    @default(1.0) // 置信度 0.0-1.0

  /// 数据来源：MANUAL | LLM_GENERATED | IMPORTED
  source       String  @default("MANUAL")
  sourceDetail String? @map("source_detail") @db.Text

  /// 审核状态：PENDING | VERIFIED | REJECTED
  reviewStatus String    @default("PENDING") @map("review_status")
  reviewNote   String?   @map("review_note") @db.Text
  reviewedAt   DateTime? @map("reviewed_at") @db.Timestamptz(6)

  notes String? @db.Text
  pack  KnowledgePack @relation(fields: [packId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([packId, reviewStatus], map: "knowledge_entries_pack_review_idx")
  @@index([canonicalName], map: "knowledge_entries_canonical_name_idx")
  @@map("knowledge_entries")
}

/// @db.remark: 书籍 ↔ 知识包 多对多关联，priority 越大越优先。
model BookKnowledgePack {
  id       String @id @default(uuid()) @db.Uuid
  bookId   String @map("book_id") @db.Uuid
  packId   String @map("pack_id") @db.Uuid
  priority Int    @default(0)

  book Book          @relation(fields: [bookId], references: [id], onDelete: Cascade)
  pack KnowledgePack @relation(fields: [packId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@unique([bookId, packId], map: "book_knowledge_pack_unique")
  @@index([bookId], map: "book_knowledge_packs_book_id_idx")
  @@map("book_knowledge_packs")
}

// ============================================================
// 姓氏条目：支持单姓/复姓，复姓优先匹配
// ============================================================
/// @db.remark: 姓氏库。extractSurname() 运行时从此表加载，优先匹配复姓。
model SurnameEntry {
  id          String  @id @default(uuid()) @db.Uuid
  surname     String  @unique // 姓氏本体，如"欧阳"/"关"
  isCompound  Boolean @default(false) @map("is_compound") // 是否复姓
  priority    Int     @default(0) // 覆盖默认优先级（越大越高，复姓建议设 10）
  description String? @db.Text

  /// 关联书籍类型（可选，表示此姓在某类型作品中多见，nil 表示通用）
  bookTypeId String?   @map("book_type_id") @db.Uuid
  bookType   BookType? @relation(fields: [bookTypeId], references: [id])

  isActive Boolean @default(true) @map("is_active")
  source   String  @default("MANUAL") // MANUAL / LLM_SUGGESTED / IMPORTED

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([isCompound, priority], map: "surname_compound_priority_idx")
  @@index([isActive], map: "surname_active_idx")
  @@map("surname_entries")
}

// ============================================================
// 泛化称谓条目
// ============================================================
/// @db.remark: 泛化称谓库。tier=SAFETY 绝不个体化，tier=DEFAULT 可被书籍类型/书籍覆盖。
model GenericTitleEntry {
  id    String @id @default(uuid()) @db.Uuid
  title String @unique // 称谓本体，如"老爷"

  /// SAFETY — 绝对泛称，任何情况下不允许个体化
  /// DEFAULT — 默认泛称，可被书籍类型 exemptGenericTitles 豁免
  tier String @default("DEFAULT") // SAFETY | DEFAULT

  /// 书籍类型级别覆盖（该称谓在哪些书籍类型下不视为泛称）
  /// JSON 数组，存储 BookType.key 列表，如 ["武侠","历史演义"]
  exemptInGenres Json? @map("exempt_in_genres") // string[]

  description String? @db.Text
  isActive    Boolean @default(true) @map("is_active")
  source      String  @default("MANUAL")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([tier, isActive], map: "generic_titles_tier_idx")
  @@map("generic_title_entries")
}

// ============================================================
// 提示词模板：每个分析阶段对应一个模板槽
// ============================================================
/// @db.remark: 提示词模板。activeVersionId 指向当前生效版本，支持一键回滚。
model PromptTemplate {
  id   String @id @default(uuid()) @db.Uuid
  /// 模板槽标识符（对应代码中的 build*Prompt 函数名）
  slug String @unique
  name String // 展示名称，如"Pass 1 独立提取"

  description String? @db.Text
  /// 原始代码函数名，方便与代码对照
  codeRef  String? @map("code_ref")
  isActive Boolean @default(true) @map("is_active")

  versions        PromptTemplateVersion[]
  /// 当前生效版本 ID
  activeVersionId String? @unique @map("active_version_id") @db.Uuid

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@map("prompt_templates")
}

// ============================================================
// 提示词版本：每次修改保存为一个新版本
// ============================================================
/// @db.remark: 提示词版本历史。每次激活都保留旧版本，支持 diff 对比与回滚。
model PromptTemplateVersion {
  id         String @id @default(uuid()) @db.Uuid
  templateId String @map("template_id") @db.Uuid

  versionNo    Int    // 自增版本号
  systemPrompt String @db.Text @map("system_prompt")
  userPrompt   String @db.Text @map("user_prompt") // 支持 {bookTitle} 等占位符

  /// 覆盖书籍类型（nil = 所有书籍类型通用）
  genreKey  String? @map("genre_key")
  changeNote String? @db.Text @map("change_note")
  createdBy  String? @map("created_by")
  isBaseline Boolean @default(false) @map("is_baseline")

  template PromptTemplate @relation(fields: [templateId], references: [id])

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@unique([templateId, versionNo], map: "prompt_version_unique")
  @@index([templateId, createdAt(sort: Desc)], map: "prompt_versions_template_created_idx")
  @@map("prompt_template_versions")
}

// ============================================================
// NER 提取规则条目
// ============================================================
/// @db.remark: NER 规则条目。ruleType=ENTITY 或 RELATIONSHIP，isActive 控制是否注入提示词。
model ExtractionRule {
  id        String @id @default(uuid()) @db.Uuid
  sortOrder Int    @default(0) @map("sort_order")

  /// ENTITY — 实体提取规则
  /// RELATIONSHIP — 关系提取规则
  ruleType String @default("ENTITY") @map("rule_type")

  content String @db.Text // 规则正文

  /// 生效范围：nil=所有书籍类型
  genreKey String? @map("genre_key")

  isActive   Boolean @default(true) @map("is_active")
  changeNote String? @db.Text @map("change_note")

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([ruleType, isActive, sortOrder], map: "extraction_rules_type_active_idx")
  @@index([genreKey], map: "extraction_rules_genre_idx")
  @@map("extraction_rules")
}

// ============================================================
// 知识变更审计日志
// ============================================================
/// @db.remark: 所有知识库对象的变更日志。
model KnowledgeAuditLog {
  id String @id @default(uuid()) @db.Uuid

  /// 被操作对象类型
  objectType String @map("object_type")
  objectId   String @map("object_id")
  objectName String @map("object_name") // 冗余名称

  /// 操作类型：CREATE | UPDATE | DELETE | VERIFY | REJECT | ACTIVATE | DEACTIVATE | IMPORT | GENERATE
  action String

  /// 变更前/后快照
  before Json? @db.JsonB
  after  Json? @db.JsonB

  /// 操作人
  operatorId   String? @map("operator_id")
  operatorNote String? @db.Text @map("operator_note")

  /// 关联书籍
  relatedBookId String? @map("related_book_id") @db.Uuid

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([objectType, objectId], map: "audit_log_object_idx")
  @@index([createdAt(sort: Desc)], map: "audit_log_created_idx")
  @@index([operatorId, createdAt(sort: Desc)], map: "audit_log_operator_idx")
  @@map("knowledge_audit_logs")
}
