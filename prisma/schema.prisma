// =============================================================================
// 三阶段人物解析架构（character extraction redesign · §0-FINAL）
// =============================================================================

/// @db.remark: Stage A 章节硬提取的 mention 候选池。
/// 语义：原文里每个称呼的每次出现都是一条记录；是否晋级为 persona 由 Stage B 聚合判定。
/// 生命周期：Stage A 写入 → Stage B 读取聚合 → 晋级后回填 promoted_persona_id。
model PersonaMention {
  id        String  @id @default(uuid()) @db.Uuid
  bookId    String  @map("book_id") @db.Uuid
  chapterId String  @map("chapter_id") @db.Uuid
  chapterNo Int     @map("chapter_no") // 冗余章节号，便于按章聚合
  jobId     String? @map("job_id") @db.Uuid // 归属 Stage A 任务（可选，便于按 job 清理）

  /// 原文出现的表层形式，如"牛浦郎"、"那范老爷"
  surfaceForm         String        @map("surface_form")
  /// Stage A 给出的别名类型提示（Stage B 可能修正）
  aliasTypeHint       AliasType     @map("alias_type_hint")
  /// 身份主张（§0-8）：Stage A 初判，UNSURE 为兜底
  identityClaim       IdentityClaim @default(UNSURE) @map("identity_claim")
  /// 疑似指向的真名（≤8 字，§0-8），作为 Stage B 三通道候选组的稳定键
  suspectedResolvesTo String?       @map("suspected_resolves_to")
  /// 叙事区段类型：NARRATIVE | POEM | DIALOGUE | COMMENTARY | UNCLASSIFIED
  narrativeRegionType String        @default("NARRATIVE") @map("narrative_region_type")
  /// 该 mention 的动作动词（§0-6 计入 effectiveBiographyCount 的必要字段）
  actionVerb          String?       @map("action_verb")
  /// 原文片段（evidence），Stage B 合并/去噪的原文证据
  rawSpan             String        @map("raw_span")
  spanStart           Int?          @map("span_start")
  spanEnd             Int?          @map("span_end")
  /// 场景绑定提示（≤30 字），用于 KINSHIP/GENERATIONAL 等泛称消歧
  sceneContextHint    String?       @map("scene_context_hint")
  /// Stage A 的本地置信度（0~1）
  confidence          Float         @default(0)

  /// 晋级后关联到正式 persona（未晋级为 null）
  promotedPersonaId String? @map("promoted_persona_id") @db.Uuid

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  book    Book         @relation(fields: [bookId], references: [id], onDelete: Cascade)
  chapter Chapter      @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  job     AnalysisJob? @relation(fields: [jobId], references: [id], onDelete: SetNull)
  persona Persona?     @relation(fields: [promotedPersonaId], references: [id], onDelete: SetNull)

  @@index([bookId, surfaceForm], map: "persona_mention_book_surface_idx")
  @@index([bookId, chapterNo], map: "persona_mention_book_chapter_idx")
  @@index([bookId, promotedPersonaId], map: "persona_mention_book_persona_idx")
  @@index([jobId], map: "persona_mention_job_idx")
  @@map("persona_mentions")
}

/// @db.remark: Stage 0 预处理结果（§0-4 覆盖率自白 + §0-2 死亡标记候选）。
/// 每个章节一条记录，输出四区段字符占比与正则死亡标记候选；unclassified>10% 打标 LOW。
model ChapterPreprocessResult {
  id        String  @id @default(uuid()) @db.Uuid
  chapterId String  @unique @map("chapter_id") @db.Uuid
  jobId     String? @map("job_id") @db.Uuid

  /// 叙事段字符占比（0~1）
  narrativeRatio    Float @default(0) @map("narrative_ratio")
  /// 诗词段字符占比
  poemRatio         Float @default(0) @map("poem_ratio")
  /// 对白段字符占比
  dialogueRatio     Float @default(0) @map("dialogue_ratio")
  /// 议论段字符占比
  commentaryRatio   Float @default(0) @map("commentary_ratio")
  /// 未分类段字符占比；>0.10 将 confidence 落为 LOW
  unclassifiedRatio Float @default(0) @map("unclassified_ratio")

  /// 预处理器信心等级：HIGH | LOW；同步写入关联 Persona.preprocessorConfidence
  confidence String @default("HIGH")

  /// 正则抽取的死亡标记候选（§0-2）：[{ marker, subject, span }]
  deathMarkers Json? @map("death_markers")
  /// 四区段字符区间明细：[{ type, start, end }]
  regions      Json?

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  chapter Chapter      @relation(fields: [chapterId], references: [id], onDelete: Cascade)
  job     AnalysisJob? @relation(fields: [jobId], references: [id], onDelete: SetNull)

  @@index([jobId], map: "chapter_preprocess_job_idx")
  @@map("chapter_preprocess_results")
}

/// @db.remark: 按 BookType 的 Prompt 变体（§0-12 / §3.7）。
/// 每个 stage × bookType 唯一，运行时替换 Prompt 正文的 {{bookTypeSpecialRules}} / {{bookTypeFewShots}} 占位符。
/// 本任务只建表，不注入 Prompt（Prompt 拼接在 T10 实现）。
model PromptTemplateVariant {
  id           String       @id @default(uuid()) @db.Uuid
  /// 模板槽标识：STAGE_A_EXTRACT_MENTIONS | STAGE_B_RESOLVE_ENTITIES | STAGE_C_ATTRIBUTE_EVENT
  templateSlug String       @map("template_slug")
  /// 所属书籍类型代码
  bookTypeCode BookTypeCode @map("book_type_code")
  /// 本 BookType 的特殊规则文本（注入 Prompt）
  specialRules String       @map("special_rules") @db.Text
  /// 若未使用 BookTypeExample 表，可直接在此内联 few-shots
  fewShotsJson Json?        @map("few_shots_json")
  active       Boolean      @default(true)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@unique([templateSlug, bookTypeCode], map: "prompt_template_variant_slug_type_key")
  @@index([bookTypeCode], map: "prompt_template_variant_type_idx")
  @@map("prompt_template_variants")
}

/// @db.remark: BookType 级 few-shot 示例池（§3.7）。
/// 运行时按 bookType+stage+priority 拼接进 Prompt。本任务只建表，不 seed。
model BookTypeExample {
  id            String       @id @default(uuid()) @db.Uuid
  bookTypeCode  BookTypeCode @map("book_type_code")
  /// 适用阶段：STAGE_A | STAGE_B | STAGE_C
  stage         String
  /// 示例标签，如"冒名识别"、"同姓分裂"
  label         String
  /// 示例输入原文片段
  exampleInput  String       @map("example_input") @db.Text
  /// 示例期望输出（JSON 字符串，由调用方解析）
  exampleOutput String       @map("example_output") @db.Text
  note          String?      @db.Text
  /// 拼接顺序（数字越大越靠前）
  priority      Int          @default(0)
  active        Boolean      @default(true)

  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([bookTypeCode, stage, priority], map: "book_type_example_lookup_idx")
  @@map("book_type_examples")
}

